# scripts/apache/cavecms.conf.template
#
# Apache vhost template for CaveCMS — mirrors the nginx template's
# behaviour for operators on Apache-based hosts (cPanel, Plesk, RHEL
# default stacks, shared hosting that doesn't ship nginx).
#
# Placeholders (substituted by install-apache.sh):
#   __APEX__        apex domain (e.g. your-domain.com)
#   __STAGING__     staging host (e.g. staging.your-domain.com)
#   __LOGIN_PATH__  hidden login path (e.g. baccess)
#   __DOC_ROOT__    install root (e.g. /opt/cavecms — same as APP_ROOT)
#   __PORT__        Node app port (default 3040)
#
# Architecture: Apache terminates TLS, serves /_next/static and
# /uploads/{originals,variants} from disk via Alias, and reverse-proxies
# everything else to 127.0.0.1:__PORT__. ErrorDocument 502 swaps in the
# maintenance HTML during the PM2/systemd reload window.
#
# Required modules (enabled by install-apache.sh):
#   proxy, proxy_http, headers, rewrite, ssl, expires, deflate, http2
#
# Inspired by Ceymail Mission Control's `mc-core::config::apache`
# (AllowOverride None + per-vhost security headers + modern TLS).

# ---------------------------------------------------------------------------
# Port 80 → 443 redirect.
# ---------------------------------------------------------------------------
<VirtualHost *:80>
    ServerName __APEX__
    ServerAlias www.__APEX__ __STAGING__
    ServerAdmin webmaster@__APEX__

    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^/?(.*) https://%{HTTP_HOST}/$1 [L,R=301]

    # Health probe is a 200 on HTTP so Cloudflare / external pingers
    # don't require TLS to confirm the box is up.
    Alias /__healthz/probe /var/cache/cavecms-healthz.txt
    <Location /__healthz/probe>
        Require all granted
    </Location>
</VirtualHost>

# ---------------------------------------------------------------------------
# HTTPS — apex + www + staging.
# ---------------------------------------------------------------------------
<VirtualHost *:443>
    ServerName __APEX__
    ServerAlias www.__APEX__ __STAGING__
    ServerAdmin webmaster@__APEX__
    DocumentRoot __DOC_ROOT__

    # ─── TLS ───────────────────────────────────────────────────────────
    SSLEngine on
    SSLCertificateFile      /etc/letsencrypt/live/__APEX__/fullchain.pem
    SSLCertificateKeyFile   /etc/letsencrypt/live/__APEX__/privkey.pem
    # Modern TLS only — no SSL3/TLS1.0/TLS1.1.
    SSLProtocol             -all +TLSv1.2 +TLSv1.3
    SSLCipherSuite          ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384
    SSLHonorCipherOrder     off
    SSLSessionTickets       off

    # HTTP/2 if mod_http2 is loaded (a2enmod http2). Falls back to
    # HTTP/1.1 gracefully when the module isn't present.
    Protocols h2 http/1.1

    # ─── Security headers ─────────────────────────────────────────────
    # For PROXIED responses the Node app is the single source of truth —
    # next.config.ts emits X-Content-Type-Options, X-Frame-Options,
    # Referrer-Policy, Permissions-Policy, COOP + CORP on every response,
    # and middleware.ts emits the CSP + a host-gated HSTS (on for real
    # public domains, off for localhost / LAN / laptop installs so Safari
    # isn't pinned to HTTPS on a plain-HTTP box — cf. CLAUDE.md #0.19).
    # Those pass through this proxy untouched, so re-setting them at the
    # vhost level here would only DUPLICATE each one (`Header always set`
    # appends to the proxied response). We therefore set NO content
    # security headers at the vhost level — only strip server-identifying
    # ones.
    #
    # IMPORTANT: /_next/static/ and /uploads/ are served DIRECTLY from
    # disk via Alias (ProxyPass ... !) and never reach Node — so those
    # responses get NO headers from the app. The required headers
    # (nosniff in particular — anti-MIME-sniff on operator/lead-uploaded
    # media) are re-applied on each Alias <Directory> below, mirroring
    # the nginx asset-headers snippet (scripts/nginx/snippets/
    # cavecms-asset-headers.conf).
    Header unset X-Powered-By
    Header unset Server

    # ─── Static + uploads (served from disk, NOT proxied to Node) ─────
    # Next.js build output: long-immutable cache because filenames are
    # content-addressed.
    Alias /_next/static/ __DOC_ROOT__/.next/static/
    <Directory __DOC_ROOT__/.next/static/>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
        Header set Cache-Control "public, max-age=31536000, immutable"
        ExpiresActive On
        ExpiresDefault "access plus 1 year"
        # Disk-served path — Node never sets headers here. Mirror the
        # app's baseline (see the Security-headers note above).
        Header always set X-Content-Type-Options "nosniff"
        Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    </Directory>

    # Operator-uploaded media (sharp variants + originals). UPLOADS_ROOT
    # is surface-dependent — the CLI puts it at <install>/uploads on
    # cPanel / laptop installs (the Apache surface) and at
    # /opt/cavecms/uploads on the VPS surface, where __DOC_ROOT__ is the
    # same /opt/cavecms install root. __DOC_ROOT__/uploads/ resolves
    # correctly for both; never hardcode an absolute path here.
    Alias /uploads/ __DOC_ROOT__/uploads/
    <Directory __DOC_ROOT__/uploads/>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
        Header set Cache-Control "public, max-age=2592000"
        # Disk-served path — Node never sets headers here. nosniff is the
        # key one: operator/lead-uploaded media is same-origin, so without
        # it a file with a benign extension but HTML/JS bytes could be
        # MIME-sniffed and executed in-origin (stored XSS → admin-session
        # compromise). HSTS keeps the public-domain guarantee consistent.
        Header always set X-Content-Type-Options "nosniff"
        Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        # Refuse executable AND browser-scriptable extensions from uploads
        # (matches the nginx template's return-404 list). nosniff alone
        # stops sniffing of mislabeled files; this also refuses correctly-
        # labeled .svg/.html/.xml/.js that would execute in-origin if ever
        # opened top-level. Operator media is only ever raster (jpeg/png/
        # webp/avif) + gated PDFs, so none of these are legitimate here.
        <FilesMatch "\.(php|phtml|cgi|pl|sh|exe|svg|html?|xhtml|xml|js|mjs)$">
            Require all denied
        </FilesMatch>
    </Directory>

    # ─── Edge-level denies (BEFORE the catch-all ProxyPass) ───────────
    # These LocationMatch blocks take effect at request-routing time so
    # they fire BEFORE ProxyPass / kicks in. Refuse direct access to
    # secret files even though Node would 404 them — defence in depth.
    #
    # Lead-gated brochure PDFs live under uploads/brochures-private/ and
    # must be served ONLY via /api/brochure/<token> (single-use, lead-
    # capture gated, cache-control: private). The Alias above disk-serves
    # the whole uploads/ tree, so without this deny a direct GET of
    # /uploads/brochures-private/<file>.pdf would bypass the lead gate.
    # Mirrors the nginx template's `return 404` for this path.
    <LocationMatch "^/uploads/brochures-private(/|$)">
        Require all denied
    </LocationMatch>
    <LocationMatch "^/(env\.production|\.env|package(-lock)?\.json|pnpm-lock\.yaml|drizzle\.config\..*)$">
        Require all denied
    </LocationMatch>
    # Refuse /.git, /.next/cache, etc.
    <LocationMatch "^/\.(git|next/cache|env)">
        Require all denied
    </LocationMatch>

    # ─── /api/internal/* — loopback-only (matches nginx template) ─────
    # The Node app's internal endpoints (security-config, revalidate-tags,
    # updates trigger-check / maintenance, audit-terminal) require the
    # request to originate on 127.0.0.1. We enforce that AT THE EDGE
    # here AND in-app via Host + bearer; either layer alone is
    # sufficient, but defence in depth survives the eventual day
    # someone adds a new /api/internal/foo route without the in-app
    # gate.
    <Location /api/internal/>
        Require ip 127.0.0.1
        Require ip ::1
    </Location>

    # ─── Static maintenance page (served from disk, NEVER proxied) ────
    # When the Node app is mid-reload (502 Bad Gateway), Apache's
    # ErrorDocument handler subrequests /maintenance.html. The
    # ProxyPass exclusion + the Alias makes that subrequest land on
    # the file in __DOC_ROOT__/public/maintenance.html, bypassing the
    # dead backend. Without the exclusion, /maintenance.html would
    # also proxy to the dead Node → 502-loop.
    ProxyPass /maintenance.html !
    Alias /maintenance.html __DOC_ROOT__/public/maintenance.html
    <Files maintenance.html>
        Require all granted
    </Files>

    # ─── Reverse proxy to Node — everything else ──────────────────────
    # Pass through Host so siteUrl-derived logic (sitemap, email links)
    # picks the right scheme + hostname.
    ProxyPreserveHost On
    ProxyAddHeaders On
    # Trust the X-Forwarded-* headers we set, NOT what the client sent.
    RequestHeader unset X-Forwarded-For
    RequestHeader unset X-Forwarded-Proto
    RequestHeader unset X-Forwarded-Host
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-Host "%{HTTP_HOST}e"
    # X-Real-IP MUST be cleared and re-set from the actual remote
    # socket — otherwise an attacker rotates `X-Real-IP: <random>` per
    # request and bypasses every per-IP rate limit, lockout escalation,
    # IP allow/blocklist gate, and maintenance bypass gate. The Node
    # app reads x-real-ip when the socket peer is loopback (always
    # true behind Apache's ProxyPass), so the header is the IP-of-
    # record. The nginx template at scripts/nginx/snippets/cavecms-
    # proxy.conf already does the equivalent.
    RequestHeader unset X-Real-IP
    RequestHeader set X-Real-IP "%{REMOTE_ADDR}s"

    # Static + uploads + maintenance.html were aliased / excluded above
    # so they exit before reaching ProxyPass. Everything else goes to
    # the Node app.
    ProxyPass /_next/static/ !
    ProxyPass /uploads/      !
    ProxyPass /              http://127.0.0.1:__PORT__/  retry=0 timeout=60 connectiontimeout=10
    ProxyPassReverse /        http://127.0.0.1:__PORT__/

    # ─── Maintenance fallback ─────────────────────────────────────────
    # Override the static maintenance page by writing your own to
    # __DOC_ROOT__/public/maintenance.html. The alias above serves it
    # directly from disk, bypassing the dead Node backend.
    ErrorDocument 502 /maintenance.html
    ErrorDocument 503 /maintenance.html
    ErrorDocument 504 /maintenance.html

    # ─── Logging (JSON-style for correlation with the Node logs) ─────
    LogFormat "{\"ts\":\"%{%Y-%m-%dT%H:%M:%S%z}t\",\"ip\":\"%a\",\"method\":\"%m\",\"path\":\"%U%q\",\"status\":%>s,\"bytes\":%B,\"rt\":%D,\"ua\":\"%{User-Agent}i\",\"ref\":\"%{Referer}i\"}" cavecms_json
    CustomLog ${APACHE_LOG_DIR}/cavecms.access.log cavecms_json
    ErrorLog  ${APACHE_LOG_DIR}/cavecms.error.log

    # ─── Disk-level hardening (belt-and-suspenders) ───────────────────
    # Even though the LocationMatch above blocks these paths at the
    # edge, refuse disk-level access too — protects against a future
    # config change that allows direct disk mapping for the install
    # root (operator switching the proxy off temporarily, etc.).
    <Directory __DOC_ROOT__>
        Options -Indexes
        AllowOverride None
    </Directory>
    <DirectoryMatch "^__DOC_ROOT__/\.(env|git|next/cache)">
        Require all denied
    </DirectoryMatch>
    <FilesMatch "^(env\.production|\.env|package(-lock)?\.json|pnpm-lock\.yaml|drizzle\.config\..*)$">
        Require all denied
    </FilesMatch>
</VirtualHost>
