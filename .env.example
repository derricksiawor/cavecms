# ============================================================================
#                    FOR CAVECMS PROJECT CONTRIBUTORS ONLY
# ============================================================================
#
# ARE YOU AN OPERATOR INSTALLING CAVECMS ON YOUR OWN SERVER?  STOP.
# You do NOT need this file.  Run:
#
#     npx create-cavecms my-site
#
# The CLI generates a sealed env.production for you (mode 600, owned by the
# cavecms system user) that you NEVER open or edit.  Everything else is in
# the admin dashboard wizard.  This file does not apply to customer installs.
#
# ----------------------------------------------------------------------------
#
# ARE YOU A CONTRIBUTOR DEVELOPING THE CAVECMS CODEBASE?  Carry on.
# Copy this to .env.local and fill in.  NEVER commit .env.local.
# This file is the contributor-dev surface only — it has no production role.
# ============================================================================


NODE_ENV=development
PORT=3040

# MariaDB connection. Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Run scripts/setup.sh (Plan 09) or manually create user + db, then `pnpm db:migrate`.
DATABASE_URL=mysql://cavecms:CHANGE_ME@127.0.0.1:3306/cavecms

# Distinct >=32-char secrets. instrumentation.ts refuses boot if any are duplicated.
# Generate each one with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_64_BYTES_BASE64
CSRF_SECRET=CHANGE_ME_64_BYTES_BASE64
PREVIEW_SECRET=CHANGE_ME_64_BYTES_BASE64
BROCHURE_SECRET=CHANGE_ME_64_BYTES_BASE64
# Bearer token used by scripts/cron-purge.ts when POSTing to
# /api/internal/revalidate-tags. The cron's revalidateTag invocations
# cannot run from a plain Node process (Next workAsyncStorage is empty),
# so they're proxied through this internal endpoint over loopback.
INTERNAL_REVALIDATE_SECRET=CHANGE_ME_64_BYTES_BASE64

# AES-256-GCM master key for encrypting operator-provided secrets at rest
# in the `settings` table (ai_config.apiKey today; SMTP password follow-up).
# MUST decode from base64 to EXACTLY 32 bytes — distinct openssl command
# from the 64-byte secrets above. Boot refuses if missing/short/duplicated.
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=CHANGE_ME_BASE64_OF_32_BYTES

# AI Assistant (Gemini, BYOK) — outbound network reachability requirements
# when AI features are enabled in the dashboard:
#   - generativelanguage.googleapis.com:443 (Gemini API)
# Boxes behind an outbound firewall must allow that host or the verify
# button + every AI feature will fail with "network_error".
# No env knob for the API key itself — operators paste it into
# Settings → AI Assistant in the admin dashboard.

# Hidden login path slug (lowercase a-z/0-9/dash, 6-32 chars). Full URL = /<LOGIN_PATH>.
# Discoverable only by direct navigation; never advertise.
LOGIN_PATH=baccess

# Session + CSRF lifetimes moved to `settings.session_config`
# (Settings → Security in the dashboard). No env knobs.

# DB pool sizing — stays env because the pool itself is what queries
# the DB (chicken-and-egg). Tune per box capacity.
DB_POOL_LIMIT=15
DB_STATEMENT_TIMEOUT_MS=10000
HANDLER_TIMEOUT_MS=15000

# Lockout tunables. CSV form, equal-length lists.
#   3 failures in window → 30min lock; 6 → 3h; 9 → 24h.
LOCKOUT_THRESHOLDS=3,6,9
LOCKOUT_DURATIONS_MIN=30,180,1440

# Optional bearer for /healthz verbose mode in production. Without it,
# verbose body is disabled in prod (status code still reflects DB health).
# Generate with: openssl rand -hex 32
# HEALTHZ_TOKEN=

# Build identifier surfaced in /healthz verbose body. Set in deploy script
# (e.g., CAVECMS_COMMIT=$(git rev-parse --short HEAD) pm2 reload …).
# CAVECMS_COMMIT=unknown

# Non-interactive admin seed (Plan 09 setup script). Leave unset for
# interactive prompt; set all three to skip prompts.
# CAVECMS_ADMIN_EMAIL=
# CAVECMS_ADMIN_NAME=
# CAVECMS_ADMIN_PASSWORD=

# reCAPTCHA v3. SITE key is public (client bundle); SECRET is server-only.
# Required in production (env.ts refuses boot otherwise).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Minimum score to accept (0.0–1.0). 0.5 is canonical. Drop to 0.0 only in
# dev/test when running automated browsers that reCAPTCHA flags as bots.
RECAPTCHA_MIN_SCORE=0.5

# Filesystem root for media uploads (Plan 02). Production: setup.sh (Plan 09)
# provisions /opt/cavecms/uploads/{originals,variants,brochures-private,.tmp}
# owned `cavecms:cavecms 750`. Dev: point at any writable path on the same filesystem.
# Production refuses a relative path at boot.
UPLOADS_ROOT=/opt/cavecms/uploads

# Site URL + name moved to `settings.site_general` — configured via
# Settings → General in the dashboard. No env vars.

# Release timestamp surfaced as sitemap.xml lastmod for static paths.
# Must parse as ISO-8601. Set in deploy script (e.g. ISO of deploy time).
CAVECMS_RELEASE_TS=2026-05-12T00:00:00Z

# SMTP + lead-notification recipient are configured via Settings →
# Email in the dashboard (DB-stored in `settings.smtp_config`). No
# env vars — operators don't edit .env on a public-CMS install.

# Hard cap on rows /api/admin/leads/export will stream in a single
# request. Default 100000. Lower this on memory-constrained boxes.
LEADS_EXPORT_MAX_ROWS=100000

# Same as above for /api/admin/newsletter/export. Default 50000 — the
# newsletter list is bounded by the unique email index, so a higher
# ceiling has no benefit on real data.
NEWSLETTER_EXPORT_MAX_ROWS=50000

# ---------------------------------------------------------------------------
# Deploy-time + systemd-timer env (NOT part of the app runtime — these
# live in /etc/cavecms/env.production on the droplet, owned root:root 640).
# Listed here for completeness and to keep the source-of-truth visible.
# Do NOT copy these into .env.local; they exist outside the Next.js
# runtime's scope and the app does not read them.
# ---------------------------------------------------------------------------
#
#   DATABASE_MIGRATOR_URL=mysql://cavecms_migrator:CHANGE_ME@127.0.0.1:3306/cavecms
#     Privileged DDL principal used by scripts/deploy.sh:307 to invoke
#     migrator-bundle/run.js. Sourced inside a subshell so the cavecms app
#     user never sees these credentials. Set during scripts/setup.sh.
#
#   BACKUP_AGE_RECIPIENT=age1...
#     Public age recipient for db-backup.sh / uploads-backup.sh
#     encrypted dumps. Setup.sh writes this from /etc/cavecms/backup.pub.
#     Operator-rotated by re-running setup.sh's age-key block (or by
#     hand if rotating without setup.sh).
#
#   BACKUP_RCLONE_REMOTE=offsite:cavecms-backups
#     Off-site rclone destination for the db + uploads tarballs. The
#     backup scripts REFUSE TO RUN without this set — off-site
#     copies are non-optional. Operator populates after the first
#     setup.sh run; see setup.sh's "NEXT STEPS" output for the
#     `rclone config` invocation that initializes the credentials.
#
# Other systemd-script tunables (defaulted in the scripts themselves
# but overridable via /etc/cavecms/env.production): SOFT_DELETE_RETENTION_DAYS,
# LOGIN_ATTEMPTS_RETENTION_DAYS, AUDIT_LOG_RETENTION_DAYS,
# NOTIFICATION_FAILURES_RETENTION_DAYS, USER_KNOWN_IPS_RETENTION_DAYS,
# RETENTION_LOCAL_DAYS, RETENTION_OFFSITE_DAYS.

# ─── Break-glass envs ──────────────────────────────────────────────
# Set ONLY during recovery; remove afterwards. Validated in lib/env.ts.
# Discoverable here so operators don't have to grep source mid-outage.
#
# LOGIN_PATH_OVERRIDE — alternate hidden login path if the primary
# LOGIN_PATH stops working (e.g. operator changed it via admin UI
# and locked themselves out before the new value propagated).
# LOGIN_PATH_OVERRIDE=

# SECURITY_DISABLE_IP_ALLOWLIST — set to '1' to bypass the admin-area
# IP allowlist for the duration of the process. Use when operator's
# work IP changed mid-trip and they can't reach the admin UI to add it.
# SECURITY_DISABLE_IP_ALLOWLIST=

# SECURITY_DISABLE_LOGIN_RECAPTCHA — set to '1' to bypass the login
# reCAPTCHA verification. Use when reCAPTCHA misconfig is blocking
# every login (wrong site key, expired secret, Google outage).
# SECURITY_DISABLE_LOGIN_RECAPTCHA=

# ─── Script override envs ──────────────────────────────────────────
# Operator-controllable flags for the bootstrap + seed + migrate scripts.
#
# CAVECMS_SEED_OK=1 — required to seed the very first admin on prod. Paired
#   with CAVECMS_ADMIN_EMAIL / CAVECMS_ADMIN_NAME / CAVECMS_ADMIN_PASSWORD for the
#   non-interactive bootstrap path (db/seed.ts).
# CAVECMS_MIGRATE_OK=1 — required to run db:migrate on prod (db-migrate-with-lock.ts).
# CAVECMS_DEV_BOOTSTRAP_ALLOW_PROD_PATH=1 — refuses by default in dev when
#   the working dir is /opt/cavecms/... ; opt-in flag for special cases.
# CAVECMS_SKIP_DOCKER=1 — skip the docker compose up dependency boot in
#   scripts/dev-bootstrap.mjs (use if managing DB manually in dev).
# CAVECMS_SKIP_PORT_CHECK=1 — skip the pre-dev port-availability gate.
# CAVECMS_DATAMIGRATION_OK=1 — required to run one-shot data migrations
#   on prod (e.g. scripts/security-reset.ts).

# ─── In-app updates feature ────────────────────────────────────────
# Powers Settings → Updates — operator-friendly self-update for non-
# technical CaveCMS owners. All variables OPTIONAL with sensible
# defaults; set them when you fork the project or change the release
# source.
#
# CAVECMS_REPO_OWNER — GitHub owner for the upstream release source.
#   Default: derricksiawor. Override when running a fork.
# CAVECMS_REPO_NAME  — GitHub repo name. Default: cavecms.
# GITHUB_PAT         — Personal Access Token for PRIVATE forks (and
#   to lift the 60-req/hr unauthenticated GitHub rate limit). Plain
#   token only — alphanumeric + underscore, no surrounding quotes.
# CAVECMS_REPO_DIR   — Absolute path to the git working tree the
#   updater operates on. Default: process cwd (the running install).
# CAVECMS_RELEASE_PROBE_URL — Reachability probe at preflight. Default:
#   https://api.github.com/zen. For the live release host, point this at
#   https://updates.cavecms.com/updates/latest.json (or your fork's host).
# CAVECMS_HEALTHZ_URL — Local /healthz the updater polls during the
#   verify step. Default: http://127.0.0.1:3040/healthz.
# CAVECMS_UPDATE_STATUS_PATH — Path to the atomic status file the
#   modal polls. Default: /var/lib/cavecms/update-status.json.
#   Path MUST resolve under /var/lib/cavecms/ or the system temp dir
#   — anything else is refused (security guard against arbitrary-file
#   overwrite via env tampering).
# CAVECMS_LOG_DIR    — Where the orchestrator writes per-step logs +
#   spawn stdout/stderr. Default: /var/log/cavecms (prod), /tmp (dev).
# CAVECMS_ENV_FILE   — Production env file the orchestrator updates
#   with the new CAVECMS_COMMIT/CAVECMS_RELEASE_TS after a successful update,
#   and that the restore orchestrator loads for its migrate step.
#   Default: /etc/cavecms/env.production. Contributors testing backup/restore
#   locally (no env.production) should point this at their .env.local so the
#   restore migrate step finds a real env file — see .env.local.
# CAVECMS_UPDATE_DRY_RUN — '1' makes the orchestrator script walk the
#   state machine on a timer without touching git/pnpm/pm2. Used by
#   the Playwright walkthrough.
# CAVECMS_FORCE_SINGLE_TREE — '1' overrides the deploy-mode coexistence
#   check (the orchestrator refuses to run when /opt/cavecms/current is a
#   symlink, i.e. the tarball-based deploy.sh path is in use). Set
#   only on single-tree installs that happen to have a stray symlink.
