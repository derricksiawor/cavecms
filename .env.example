# Copy to .env.local and fill in. NEVER commit .env.local.

NODE_ENV=development
PORT=3040

# MariaDB connection. Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Run scripts/setup.sh (Plan 09) or manually create user + db, then `pnpm db:migrate`.
DATABASE_URL=mysql://bwc:CHANGE_ME@127.0.0.1:3306/bwc

# Distinct >=32-char secrets. instrumentation.ts refuses boot if any are duplicated.
# Generate each one with: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_64_BYTES_BASE64
CSRF_SECRET=CHANGE_ME_64_BYTES_BASE64
PREVIEW_SECRET=CHANGE_ME_64_BYTES_BASE64
BROCHURE_SECRET=CHANGE_ME_64_BYTES_BASE64
# Bearer token used by scripts/cron-purge.ts when POSTing to
# /api/internal/revalidate-tags. The cron's revalidateTag invocations
# cannot run from a plain Node process (Next workAsyncStorage is empty),
# so they're proxied through this internal endpoint over loopback.
INTERNAL_REVALIDATE_SECRET=CHANGE_ME_64_BYTES_BASE64

# Hidden login path slug (lowercase a-z/0-9/dash, 6-32 chars). Full URL = /<LOGIN_PATH>.
# Discoverable only by direct navigation; never advertise.
LOGIN_PATH=baccess

# Tunables (defaults from lib/env.ts)
JWT_TTL_SECONDS=28800
JWT_RENEW_AFTER_SECONDS=1800
JWT_ABSOLUTE_MAX_SECONDS=86400
CSRF_TTL_SECONDS=3600
DB_POOL_LIMIT=15
DB_STATEMENT_TIMEOUT_MS=10000
HANDLER_TIMEOUT_MS=15000

# Lockout tunables. CSV form, equal-length lists.
#   3 failures in window → 30min lock; 6 → 3h; 9 → 24h.
LOCKOUT_THRESHOLDS=3,6,9
LOCKOUT_DURATIONS_MIN=30,180,1440

# Optional bearer for /healthz verbose mode in production. Without it,
# verbose body is disabled in prod (status code still reflects DB health).
# Generate with: openssl rand -hex 32
# HEALTHZ_TOKEN=

# Build identifier surfaced in /healthz verbose body. Set in deploy script
# (e.g., BWC_COMMIT=$(git rev-parse --short HEAD) pm2 reload …).
# BWC_COMMIT=unknown

# Non-interactive admin seed (Plan 09 setup script). Leave unset for
# interactive prompt; set all three to skip prompts.
# BWC_ADMIN_EMAIL=
# BWC_ADMIN_NAME=
# BWC_ADMIN_PASSWORD=

# reCAPTCHA v3. SITE key is public (client bundle); SECRET is server-only.
# Required in production (env.ts refuses boot otherwise).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Minimum score to accept (0.0–1.0). 0.5 is canonical. Drop to 0.0 only in
# dev/test when running automated browsers that reCAPTCHA flags as bots.
RECAPTCHA_MIN_SCORE=0.5

# Filesystem root for media uploads (Plan 02). Production: setup.sh (Plan 09)
# provisions /opt/bwc/uploads/{originals,variants,brochures-private,.tmp}
# owned `bwc:bwc 750`. Dev: point at any writable path on the same filesystem.
# Production refuses a relative path at boot.
UPLOADS_ROOT=/opt/bwc/uploads

# Canonical public origin — used by JSON-LD `url` fields, sitemap.xml,
# robots.txt's Host directive, and all absolute URLs in outbound email
# (brochure download links, newsletter confirm/unsubscribe URLs).
# Must be https:// with no trailing slash. Staging deploys override
# to https://staging.bestworldcompany.com so emailed links don't
# bleed staging visitors to production.
SITE_ORIGIN=https://bestworldcompany.com

# Release timestamp surfaced as sitemap.xml lastmod for static paths.
# Must parse as ISO-8601. Set in deploy script (e.g. ISO of deploy time).
BWC_RELEASE_TS=2026-05-12T00:00:00Z

# Outbound SMTP (Plan 07). Required in production; optional in dev
# (the email queue short-circuits when SMTP_HOST is unset, leaving
# pending_emails rows for replay once credentials land).
# SMTP_HOST set ⇒ SMTP_FROM required (env.ts refuses boot otherwise).
# SMTP_USER set ⇒ SMTP_PASS required.
# SMTP_FROM accepts bare 'a@b.co' or 'Name <a@b.co>' display form.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Internal recipient for new-lead notifications (sales inbox).
# Falls back to SMTP_FROM when unset.
SALES_EMAIL=

# Hard cap on rows /api/admin/leads/export will stream in a single
# request. Default 100000. Lower this on memory-constrained boxes.
LEADS_EXPORT_MAX_ROWS=100000

# Same as above for /api/admin/newsletter/export. Default 50000 — the
# newsletter list is bounded by the unique email index, so a higher
# ceiling has no benefit on real data.
NEWSLETTER_EXPORT_MAX_ROWS=50000

# ---------------------------------------------------------------------------
# Deploy-time + systemd-timer env (NOT part of the app runtime — these
# live in /etc/bwc/env.production on the droplet, owned root:root 640).
# Listed here for completeness and to keep the source-of-truth visible.
# Do NOT copy these into .env.local; they exist outside the Next.js
# runtime's scope and the app does not read them.
# ---------------------------------------------------------------------------
#
#   DATABASE_MIGRATOR_URL=mysql://bwc_migrator:CHANGE_ME@127.0.0.1:3306/bwc
#     Privileged DDL principal used by scripts/deploy.sh:307 to invoke
#     migrator-bundle/run.js. Sourced inside a subshell so the bwc app
#     user never sees these credentials. Set during scripts/setup.sh.
#
#   BACKUP_AGE_RECIPIENT=age1...
#     Public age recipient for db-backup.sh / uploads-backup.sh
#     encrypted dumps. Setup.sh writes this from /etc/bwc/backup.pub.
#     Operator-rotated by re-running setup.sh's age-key block (or by
#     hand if rotating without setup.sh).
#
#   BACKUP_RCLONE_REMOTE=offsite:bwc-backups
#     Off-site rclone destination for the db + uploads tarballs. The
#     backup scripts REFUSE TO RUN without this set — off-site
#     copies are non-optional. Operator populates after the first
#     setup.sh run; see setup.sh's "NEXT STEPS" output for the
#     `rclone config` invocation that initializes the credentials.
#
# Other systemd-script tunables (defaulted in the scripts themselves
# but overridable via /etc/bwc/env.production): SOFT_DELETE_RETENTION_DAYS,
# LOGIN_ATTEMPTS_RETENTION_DAYS, AUDIT_LOG_RETENTION_DAYS,
# NOTIFICATION_FAILURES_RETENTION_DAYS, USER_KNOWN_IPS_RETENTION_DAYS,
# RETENTION_LOCAL_DAYS, RETENTION_OFFSITE_DAYS.

# ─── Break-glass envs ──────────────────────────────────────────────
# Set ONLY during recovery; remove afterwards. Validated in lib/env.ts.
# Discoverable here so operators don't have to grep source mid-outage.
#
# LOGIN_PATH_OVERRIDE — alternate hidden login path if the primary
# LOGIN_PATH stops working (e.g. operator changed it via admin UI
# and locked themselves out before the new value propagated).
# LOGIN_PATH_OVERRIDE=

# SECURITY_DISABLE_IP_ALLOWLIST — set to '1' to bypass the admin-area
# IP allowlist for the duration of the process. Use when operator's
# work IP changed mid-trip and they can't reach the admin UI to add it.
# SECURITY_DISABLE_IP_ALLOWLIST=

# SECURITY_DISABLE_LOGIN_RECAPTCHA — set to '1' to bypass the login
# reCAPTCHA verification. Use when reCAPTCHA misconfig is blocking
# every login (wrong site key, expired secret, Google outage).
# SECURITY_DISABLE_LOGIN_RECAPTCHA=

# ─── Script override envs ──────────────────────────────────────────
# Operator-controllable flags for the bootstrap + seed + migrate scripts.
#
# BWC_SEED_OK=1 — required to seed the very first admin on prod. Paired
#   with BWC_ADMIN_EMAIL / BWC_ADMIN_NAME / BWC_ADMIN_PASSWORD for the
#   non-interactive bootstrap path (db/seed.ts).
# BWC_MIGRATE_OK=1 — required to run db:migrate on prod (db-migrate-with-lock.ts).
# BWC_DEV_BOOTSTRAP_ALLOW_PROD_PATH=1 — refuses by default in dev when
#   the working dir is /opt/bwc/... ; opt-in flag for special cases.
# BWC_SKIP_DOCKER=1 — skip the docker compose up dependency boot in
#   scripts/dev-bootstrap.mjs (use if managing DB manually in dev).
# BWC_SKIP_PORT_CHECK=1 — skip the pre-dev port-availability gate.
# BWC_DATAMIGRATION_OK=1 — required to run one-shot data migrations
#   on prod (e.g. scripts/security-reset.ts).
