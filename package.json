{
  "name": "cavecms",
  "version": "0.1.59",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Derrick S. K. Siawor",
  "description": "CaveCMS — AI-native CMS on Next.js. Prosperity Public License 3.0.0 (free for noncommercial; 30-day commercial trial).",
  "homepage": "https://cavecms.derricksiawor.com",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "predev": "node --env-file-if-exists=.env.local scripts/dev-bootstrap.mjs && node --env-file-if-exists=.env.local --import tsx scripts/verify-route-collisions.ts",
    "predev:turbo": "node --env-file-if-exists=.env.local scripts/dev-bootstrap.mjs && node --env-file-if-exists=.env.local --import tsx scripts/verify-route-collisions.ts",
    "dev": "next dev -p 3040",
    "dev:turbo": "next dev -p 3040 --turbopack",
    "prebuild": "node --env-file-if-exists=.env.local scripts/dev-bootstrap.mjs && node --env-file-if-exists=.env.local --import tsx scripts/verify-route-collisions.ts && pnpm validate:site-templates",
    "build": "next build",
    "postbuild": "node --env-file-if-exists=.env.local --import tsx scripts/postbuild-patch-trust-host-header.ts && node --env-file-if-exists=.env.local --import tsx scripts/postbuild-check-slug-collisions.ts",
    "prestart": "node --env-file-if-exists=.env.local scripts/dev-bootstrap.mjs",
    "start": "node --env-file-if-exists=.env.local scripts/start-standalone.mjs",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:changed": "F=\"$(git diff --name-only --diff-filter=ACMR HEAD -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.mjs' '*.cjs'; git ls-files --others --exclude-standard -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.mjs' '*.cjs')\"; if [ -n \"$F\" ]; then echo \"$F\" | xargs eslint --cache --cache-location .eslintcache; else echo 'lint:changed: nothing to lint'; fi",
    "typecheck": "tsc --noEmit",
    "validate:site-templates": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/validate-site-templates.ts",
    "test": "vitest run",
    "test:integration": "node --env-file=.env.local node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "db:generate": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:pre-migrate-asserts": "node --env-file=.env.local --import tsx scripts/pre-migrate-asserts.ts",
    "db:post-migrate-asserts": "node --env-file=.env.local --import tsx scripts/post-migrate-asserts.ts",
    "db:migrate": "pnpm db:pre-migrate-asserts && node --env-file=.env.local --import tsx scripts/db-migrate-with-lock.ts && pnpm db:post-migrate-asserts && pnpm db:fingerprint",
    "db:fingerprint": "node --conditions=react-server --env-file=.env.local --import tsx scripts/update-fingerprint.ts",
    "db:check": "node --conditions=react-server --env-file=.env.local --import tsx scripts/check-fingerprint.ts",
    "db:studio": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "node --conditions=react-server --env-file=.env.local --import tsx db/seed.ts",
    "migrate:projects-to-blocks": "node --conditions=react-server --env-file-if-exists=.env.local --import tsx scripts/migrate-projects-to-blocks.ts",
    "release:build-template-media": "node --conditions=react-server --dns-result-order=ipv4first --env-file-if-exists=.env.local --import tsx scripts/release/build-template-media.ts",
    "template-media:hydrate": "node --dns-result-order=ipv4first --env-file-if-exists=.env.local --import tsx scripts/release/hydrate-template-media.ts",
    "release:build": "node scripts/release/build-zip.mjs",
    "release:publish": "node scripts/release/publish.mjs",
    "release": "pnpm release:build && pnpm release:publish"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@google/genai": "2.6.0",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "drizzle-orm": "0.45.2",
    "file-type": "22.0.1",
    "framer-motion": "11.18.2",
    "gsap": "3.15.0",
    "isomorphic-dompurify": "2.36.0",
    "jose": "5.10.0",
    "lucide-react": "1.14.0",
    "microdiff": "1.5.0",
    "mysql2": "3.22.3",
    "next": "15.5.18",
    "nodemailer": "8.0.8",
    "react": "19.1.7",
    "react-colorful": "5.7.0",
    "react-dom": "19.1.7",
    "react-markdown": "9.1.0",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "server-only": "0.0.1",
    "sharp": "0.33.5",
    "tsx": "4.21.0",
    "unified": "11.0.5",
    "zod": "3.25.76"
  },
  "pnpm": {
    "overrides": {
      "next": "15.5.18",
      "ws": ">=8.21.0"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "22.19.18",
    "@types/nodemailer": "8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.27.2",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.18",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.2",
    "vitest": "2.1.9"
  }
}
